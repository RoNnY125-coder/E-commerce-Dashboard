# ═══════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce_dashboard"

# ═══════════════════════════════════════════
# REDIS (for session blacklist + rate limiting)
# ═══════════════════════════════════════════
REDIS_URL="redis://localhost:6379"

# ═══════════════════════════════════════════
# JWT SECRETS (generate with: openssl rand -base64 64)
# ═══════════════════════════════════════════
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-for-production"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string-for-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ═══════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# ═══════════════════════════════════════════
# CLOUDINARY (avatar & product image uploads)
# Get at: https://cloudinary.com/
# ═══════════════════════════════════════════
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ═══════════════════════════════════════════
# SENDGRID (transactional email)
# Get at: https://sendgrid.com/
# ═══════════════════════════════════════════
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@yourstore.com"
EMAIL_FROM_NAME="Commerce Pro"

# ═══════════════════════════════════════════
# GOOGLE OAUTH (optional)
# Get at: https://console.cloud.google.com/
# ═══════════════════════════════════════════
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ═══════════════════════════════════════════
# FRONTEND (Vite env vars — copy to .env in root)
# ═══════════════════════════════════════════
VITE_API_URL="http://localhost:3001"
