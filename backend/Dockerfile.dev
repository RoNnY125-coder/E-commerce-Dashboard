# Dockerfile.dev for local development with hot reloading
FROM node:20-alpine

WORKDIR /usr/src/app

COPY package*.json ./
RUN npm install

# We don't copy the source code here because it will be mounted as a volume in docker-compose
# We just need prisma schema for generation
COPY prisma ./prisma/
RUN npx prisma generate

EXPOSE 3001

CMD ["npm", "run", "dev"]
