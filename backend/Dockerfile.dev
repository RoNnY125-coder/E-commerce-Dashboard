FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

# Copy prisma schema so we can generate the client
COPY prisma ./prisma/
RUN npx prisma generate

# Source is mounted as a volume in docker-compose.dev.yml (hot-reload)
# We only pre-install deps and generate prisma here

EXPOSE 3001

# Run migrations on startup, then launch dev server with hot-reload
CMD ["sh", "-c", "npx prisma migrate dev --name init --skip-seed 2>/dev/null || npx prisma migrate deploy && npm run dev"]
